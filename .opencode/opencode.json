{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "Qwen3.5-9B-opus-distilled",
      "temperature": 0.55,
      "maxSteps": 30
    },
    "review": {
      "description": "Reviews Python code for type safety, test coverage, and medical RAG patterns",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0,
      "permissions": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "eval": {
      "description": "Runs the eval harness and interprets calibration results",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0,
      "permissions": {
        "bash": "ask",
        "edit": "deny",
        "write": "deny"
      }
    }
  }
}
