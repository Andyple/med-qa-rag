# NCBI API Key (Optional but recommended for high-volume fetching)
NCBI_API_KEY=your_ncbi_api_key_here

# Local LLM Server (e.g., llama-server / llama.cpp)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=auto-detect  # Set to "auto-detect" to fetch from server

# Local Embedding Server
EMBEDDING_BASE_URL=http://localhost:8081/v1
EMBEDDING_MODEL=embeddinggemma-300m

# API Keys (leave empty if your local server doesn't require them)
OPENAI_API_KEY=not-needed-for-local
